              {
                "name": "scanId",
                "value": "",
                "type": "path",
                "description": "Unique identifier of the scan"
              }
            ]
          },
          "docs": "Retrieves the scan log for a specific scan."
        },
        {
          "info": {
            "name": "Fortify Get scan summary",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "{protocol}://{host}/api/scans/:scanId/scan-summary",
